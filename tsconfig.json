{
	"compilerOptions": {
		"baseUrl": "src",
		"paths": {
			"@components/*": [
				"components/*"
			],
			"@utils/*": [
				"utils/*"
			],
			"@layouts/*": [
				"layouts/*"
			]
		}
	},
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist"
	]
}